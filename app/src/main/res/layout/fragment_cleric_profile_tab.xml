<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvClericName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Клирик"
            android:textColor="@color/korich"
            android:textSize="20sp"
            android:fontFamily="serif"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvClericRank"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Сан"
            android:textColor="@color/button"
            android:textSize="15sp"
            android:fontFamily="serif" />

        <TextView
            android:id="@+id/tvClericChurch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/korich"
            android:textSize="14sp"
            android:fontFamily="serif" />

        <TextView
            android:id="@+id/tvClericInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/korich"
            android:textSize="13sp"
            android:fontFamily="serif" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="@color/button" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Всего праздничных литургий:"
            android:textColor="@color/obichni"
            android:textSize="13sp"
            android:fontFamily="serif" />

        <TextView
            android:id="@+id/tvTotalLiturgies"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="0"
            android:textColor="@color/korich"
            android:textSize="18sp"
            android:fontFamily="serif" />

        <TextView
            android:id="@+id/btnClericLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Выйти"
            android:textColor="@color/button"
            android:textSize="14sp"
            android:fontFamily="serif" />
    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fon2"
    tools:context=".MetropolitanOrdersActivity">

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleOrderType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:checkedButton="@id/btnWorkshopOrders"
        app:layout_constraintTop_toTopOf="parent"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMoscowOrders"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Документы"
            android:textAllCaps="false"
            android:textColor="@color/text"
            app:backgroundTint="@color/obichni"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWorkshopOrders"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Награды"
            android:textAllCaps="false"
            android:textColor="@color/text"
            app:backgroundTint="@color/korich"
            app:cornerRadius="10dp" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <EditText
        android:id="@+id/etSearchName"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_chip_normal"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="8dp"
        android:fontFamily="serif"
        android:hint="Введите ФИО"
        android:inputType="text"
        android:paddingHorizontal="12dp"
        android:textColor="@color/korich"
        android:textColorHint="@color/button"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/toggleOrderType" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMetOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavMet"
        app:layout_constraintTop_toBottomOf="@id/etSearchName" />

    <TextView
        android:id="@+id/tvMetEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="Нет заявок"
        android:textColor="@color/button"
        android:textSize="15sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavMet"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etSearchName" />

    <LinearLayout
        android:id="@+id/bottomNavMet"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/navMetDashboard"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:contentDescription="Дашборд"
            android:scaleType="centerInside"
            android:src="@drawable/ic_nav_list" />

        <ImageView
            android:id="@+id/navMetOrders"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:contentDescription="Заявки"
            android:scaleType="centerInside"
            android:src="@drawable/ic_nav_sent_active" />

        <ImageView
            android:id="@+id/navMetDiary"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:contentDescription="Личный дневник"
            android:scaleType="centerInside"
            android:src="@drawable/ic_nav_book_k" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

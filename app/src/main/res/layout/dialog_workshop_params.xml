<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/btnCloseParams"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="end"
            android:contentDescription="Закрыть"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/korich" />

        <TextView
            android:id="@+id/tvParamsAwardTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="serif"
            android:gravity="center"
            android:textColor="@color/korich"
            android:textSize="20sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="serif"
            android:text="Мастерская"
            android:textColor="@color/button"
            android:textSize="13sp"
            android:textStyle="italic" />

        <Spinner
            android:id="@+id/spinnerWorkshopParams"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@android:drawable/btn_dropdown" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="serif"
            android:text="Цена"
            android:textColor="@color/button"
            android:textSize="13sp"
            android:textStyle="italic" />

        <TextView
            android:id="@+id/tvParamsPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="serif"
            android:textColor="@color/korich"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSizeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="serif"
            android:text="Размер"
            android:textColor="@color/button"
            android:textSize="13sp"
            android:textStyle="italic" />

        <LinearLayout
            android:id="@+id/llSizesRow1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal" />

        <LinearLayout
            android:id="@+id/llSizesRow2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="serif"
            android:text="На какую дату"
            android:textColor="@color/button"
            android:textSize="13sp"
            android:textStyle="italic" />

        <LinearLayout
            android:id="@+id/llDates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="serif"
            android:text="Комментарий"
            android:textColor="@color/button"
            android:textSize="13sp"
            android:textStyle="italic" />

        <EditText
            android:id="@+id/etComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_chip_normal"
            android:fontFamily="serif"
            android:gravity="top|start"
            android:hint="Комментарий к заказу..."
            android:inputType="textMultiLine"
            android:minHeight="80dp"
            android:padding="12dp"
            android:textColor="@color/korich"
            android:textColorHint="@color/button"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitOrder"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="Отправить в мастерскую"
            android:textAllCaps="false"
            android:textColor="@color/text"
            app:backgroundTint="@color/korich"
            app:cornerRadius="10dp" />

    </LinearLayout>
</ScrollView>

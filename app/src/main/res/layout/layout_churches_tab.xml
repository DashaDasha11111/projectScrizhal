<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/churchesTabRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Churches list panel -->
    <LinearLayout
        android:id="@+id/churchesListPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:visibility="visible">

        <EditText
            android:id="@+id/churchesSearch"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_clerics_search"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="8dp"
            android:fontFamily="serif"
            android:hint="Введите название храма"
            android:inputType="text"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/korich"
            android:textColorHint="@color/obichni" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/churchesRecycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />
    </LinearLayout>

    <!-- Liturgy assignments panel -->
    <LinearLayout
        android:id="@+id/liturgyPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleLiturgyFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:checkedButton="@id/btnUnassigned"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUnassigned"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Не назначенные"
                android:textAllCaps="false"
                android:textColor="@color/bel"
                app:backgroundTint="@color/korich"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAssigned"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Назначенные"
                android:textAllCaps="false"
                android:textColor="@color/korich"
                app:backgroundTint="@color/obichni"
                app:cornerRadius="10dp" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:id="@+id/tvLiturgyEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="serif"
            android:text="Нет литургий"
            android:textColor="@color/button"
            android:textSize="15sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFeasts"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

    </LinearLayout>

    <!-- Карта храмов: назначения на выбранный праздник -->
    <LinearLayout
        android:id="@+id/mapPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="Праздник для отображения"
            android:textColor="@color/obichni"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/spinnerMapFeast"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@android:drawable/btn_dropdown" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/map_marker_assigned" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="serif"
                android:text="Назначено"
                android:textColor="@color/korich"
                android:textSize="12sp" />

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/map_marker_free" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="serif"
                android:text="Не назначено"
                android:textColor="@color/korich"
                android:textSize="12sp" />
        </LinearLayout>

        <org.osmdroid.views.MapView
            android:id="@+id/churchMapView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1" />
    </LinearLayout>

</FrameLayout>

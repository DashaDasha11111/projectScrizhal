<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/btnCloseReview"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="end"
            android:contentDescription="Закрыть"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/korich" />

        <TextView
            android:id="@+id/tvReviewAwardTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="serif"
            android:gravity="center"
            android:textColor="@color/korich"
            android:textSize="20sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="serif"
            android:text="Для кого"
            android:textColor="@color/button"
            android:textSize="13sp"
            android:textStyle="italic" />

        <TextView
            android:id="@+id/tvReviewRecipient"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="serif"
            android:textColor="@color/korich"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="serif"
            android:text="Цена"
            android:textColor="@color/button"
            android:textSize="13sp"
            android:textStyle="italic" />

        <TextView
            android:id="@+id/tvReviewPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="serif"
            android:textColor="@color/korich"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Size section (hidden if no size) -->
        <TextView
            android:id="@+id/tvReviewSizeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="serif"
            android:text="Размер"
            android:textColor="@color/button"
            android:textSize="13sp"
            android:textStyle="italic" />

        <LinearLayout
            android:id="@+id/llReviewSizesRow1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal" />

        <LinearLayout
            android:id="@+id/llReviewSizesRow2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal" />

        <!-- Date section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="serif"
            android:text="На какую дату"
            android:textColor="@color/button"
            android:textSize="13sp"
            android:textStyle="italic" />

        <LinearLayout
            android:id="@+id/llReviewDates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal" />

        <!-- Comment section -->
        <TextView
            android:id="@+id/tvReviewCommentLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="serif"
            android:text="Комментарий"
            android:textColor="@color/button"
            android:textSize="13sp"
            android:textStyle="italic" />

        <TextView
            android:id="@+id/tvReviewComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_chip_normal"
            android:fontFamily="serif"
            android:minHeight="60dp"
            android:padding="12dp"
            android:textColor="@color/korich"
            android:textSize="13sp" />

        <!-- Accept / Reject buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAcceptOrder"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="Принять"
                android:textAllCaps="false"
                android:textColor="@color/text"
                app:backgroundTint="@color/korich"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRejectOrder"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Отклонить"
                android:textAllCaps="false"
                android:textColor="@color/text"
                app:backgroundTint="@color/obichni"
                app:cornerRadius="10dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>

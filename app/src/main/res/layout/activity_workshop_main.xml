<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fon2"
    tools:context=".WorkshopMainActivity">

    <ImageView
        android:id="@+id/btnWsLogout"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="Выйти"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="@color/korich"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:padding="16dp"
        android:text="Новые заказы"
        android:textColor="@color/korich"
        android:textSize="20sp"
        app:layout_constraintEnd_toStartOf="@id/btnWsLogout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/etSearchChurch"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_chip_normal"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="8dp"
        android:fontFamily="serif"
        android:hint="Введите название храма"
        android:inputType="text"
        android:paddingHorizontal="12dp"
        android:textColor="@color/korich"
        android:textColorHint="@color/button"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <Spinner
        android:id="@+id/spinnerArchiveFilter"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_chip_normal"
        android:fontFamily="serif"
        android:paddingHorizontal="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/etSearchChurch" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav"
        app:layout_constraintTop_toBottomOf="@+id/spinnerArchiveFilter" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="Нет новых заказов"
        android:textColor="@color/button"
        android:textSize="15sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/spinnerArchiveFilter" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/navInbox"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:contentDescription="Новые"
            android:scaleType="centerInside"
            android:src="@drawable/ic_nav_inbox_active" />

        <ImageView
            android:id="@+id/navInWork"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:contentDescription="В работе"
            android:scaleType="centerInside"
            android:src="@drawable/ic_nav_sent" />

        <ImageView
            android:id="@+id/navArchive"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:contentDescription="Архив"
            android:scaleType="centerInside"
            android:src="@drawable/ic_nav_done" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/clericsTabRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="16dp">

    <EditText
        android:id="@+id/clericsSearch"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_clerics_search"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="8dp"
        android:fontFamily="serif"
        android:hint="Введите ФИО"
        android:inputType="text"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="@color/korich"
        android:textColorHint="@color/obichni" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Spinner
            android:id="@+id/clericsSpinnerRanks"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@android:drawable/btn_dropdown"
            android:minWidth="80dp" />

        <Spinner
            android:id="@+id/clericsSpinnerTypes"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@android:drawable/btn_dropdown"
            android:minWidth="80dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clericsBtnAdd"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:text="Добавить"
            android:textAllCaps="false"
            android:textColor="@color/text"
            app:backgroundTint="@color/obichni"
            app:cornerRadius="8dp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/clericsRecycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />
</LinearLayout>

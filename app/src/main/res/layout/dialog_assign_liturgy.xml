<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvFeastTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Праздник"
        android:textColor="@color/korich"
        android:textSize="16sp"
        android:fontFamily="serif"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Храм"
        android:textColor="@color/obichni"
        android:textSize="12sp"
        android:fontFamily="serif" />

    <TextView
        android:id="@+id/tvAssignChurchName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="serif"
        android:textColor="@color/korich"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Дата"
        android:textColor="@color/obichni"
        android:textSize="12sp"
        android:fontFamily="serif" />

    <EditText
        android:id="@+id/etFeastDate"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_clerics_search"
        android:inputType="text"
        android:padding="8dp"
        android:textColor="@color/korich"
        android:textColorHint="@color/obichni"
        android:fontFamily="serif" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Священнослужители"
        android:textColor="@color/obichni"
        android:textSize="12sp"
        android:fontFamily="serif" />

    <ListView
        android:id="@+id/lvClerics"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="4dp"
        android:choiceMode="multipleChoice" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/btnCancelAssign"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Отмена" />

        <Button
            android:id="@+id/btnSaveAssign"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Назначить" />
    </LinearLayout>

</LinearLayout>
